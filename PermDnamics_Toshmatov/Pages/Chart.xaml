<Page x:Class="PermDnamics_Toshmatov.Pages.Chart"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PermDnamics_Toshmatov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="420" d:DesignWidth="793.6"
      Title="Chart" SizeChanged="Page_SizeChanged" >

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\ЗС\OneDrive\Рабочий стол\PermDnamics_Toshmatov\PermDnamics_Toshmatov\Images\chart.png" />
        </Grid.Background>
        <ScrollViewer x:Name="scroll" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
            <StackPanel>
                <Canvas x:Name="canvas" Width="793.6" Height="200" Margin="0,0,10,5" Background="#1E000000"/>
                <Canvas x:Name="canvasVolatility" Width="793.6"  Height="200" Margin="-10,15,0,0" Background="#1E000000"/>
            </StackPanel>
        </ScrollViewer>
        <Grid Width="200" Height="100" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,10" Background="#7FFFFFFF">
            <Label x:Name="current_value" Content="Тек. знач:" Margin="10,10,10,0" VerticalAlignment="Top" />
            <Label x:Name="average_value" Content="Сред. знач:" Margin="10,36,10,0" VerticalAlignment="Top" />

        </Grid>
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,10" Background="#7FFFFFFF">
            <TextBox x:Name="tbSaveName" Text="График" Width="120" Height="25" Margin="5"/>
            <Button x:Name="btnSave" Content="Сохранить" Height="30" Width="100" Margin="5" Click="SaveChart_Click"/>
            <Button x:Name="btnLoad" Content="Загрузить" Height="30" Width="100" Margin="5" Click="LoadChart_Click"/>
        </StackPanel>

    </Grid>
</Page>
